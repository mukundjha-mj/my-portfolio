# ─────────────────────────────────────────────────────────────
#  Copy this file to `.env` and fill in the values.
#  Needed for the Guestbook (auth + database). The rest of the
#  site runs without any of these.
# ─────────────────────────────────────────────────────────────

# Postgres connection string (Neon / Supabase / Vercel Postgres).
# Neon example: postgresql://user:pass@ep-xxx.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=""

# Auth.js secret — generate one with:  bunx auth secret   (or: openssl rand -base64 33)
AUTH_SECRET=""

# GitHub OAuth app → https://github.com/settings/developers  (New OAuth App)
#   Homepage URL:            http://localhost:3000
#   Authorization callback:  http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Google OAuth → https://console.cloud.google.com/apis/credentials  (OAuth client ID → Web app)
#   Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# In production, also set (Auth.js infers these on Vercel automatically):
# AUTH_URL="https://yourdomain.dev"
