# ─────────────────────────────────────────────────────────────
#  Copy this file to `.env` and fill in the values.
#  Needed for the Guestbook (auth + database). The rest of the
#  site runs without any of these.
# ─────────────────────────────────────────────────────────────

# Postgres connection string (Neon / Supabase / Vercel Postgres).
# Neon example: postgresql://user:pass@ep-xxx.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=""

# Clerk (auth) → https://dashboard.clerk.com → Create application
#   1. Create an application (any name).
#   2. In "Configure" → "SSO Connections", enable GitHub and Google.
#   3. Copy the keys below from "API Keys".
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
