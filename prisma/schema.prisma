// Prisma schema — Guestbook only. Auth is handled by Clerk (no local
// User/Account/Session tables — see auth via @clerk/nextjs's `auth()`).
// Provider is PostgreSQL (Neon/Supabase). Set DATABASE_URL in .env.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Guestbook ─────────────────────────────────────────────────
// The poster's identity is denormalized onto the entry (Clerk user id +
// a snapshot of their name/avatar at post time) — a guestbook entry is a
// point-in-time note, so it doesn't need to track live profile changes.
model GuestbookEntry {
  id          String   @id @default(cuid())
  body        String   @db.Text
  createdAt   DateTime @default(now())
  authorId    String
  authorName  String?
  authorImage String?

  @@index([createdAt])
}
